<!DOCTYPE html>
<html lang="no">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Petterprinter05</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800;900&family=Inter:wght@300;400;500;600;700;800;900&display=swap');
  :root {
    --bg: #080c14; --bg2: #0c1220; --bg3: #101828; --bg4: #141f2e;
    --blue: #1a3a5c; --blue2: #2d6a9f; --blue3: #0f2540;
    --slate: #8899aa; --light: #dde6f0; --white: #f0f4f8;
    --red: #e05252; --card: #0f1a28; --border: rgba(45,106,159,0.2);
    --accent: #4a9eff;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:auto;}
  body{background:var(--bg);color:var(--white);font-family:'Inter',system-ui,sans-serif;line-height:1.6;overflow-x:hidden;}
  h1,h2{font-family:'Playfair Display',Georgia,serif;}

  /* ===================== TICKER ===================== */
  .ticker-wrap{background:var(--bg3);border-bottom:1px solid var(--border);padding:0.4rem 0;overflow:hidden;white-space:nowrap;position:relative;z-index:101;}
  .ticker{display:inline-block;animation:ticker 28s linear infinite;}
  .ticker span{margin:0 2.5rem;font-size:0.78rem;letter-spacing:0.3px;}
  .ticker .up{color:var(--accent);}
  .ticker .dn{color:var(--red);}
  .ticker .sym{color:var(--slate);margin-right:0.4rem;}
  @keyframes ticker{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}

  /* ===================== NAV ===================== */
  nav{position:fixed;top:33px;width:100%;z-index:100;background:rgba(8,12,20,0.88);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;padding:0.9rem 2.5rem;transition:top 0.3s;}
  nav.scrolled{top:0;}
  .nav-logo{font-weight:800;font-size:1rem;color:var(--accent);letter-spacing:1px;text-transform:uppercase;font-family:'Playfair Display',serif;}
  .nav-logo span{color:var(--white);font-weight:300;}
  .nav-links{display:flex;gap:2rem;list-style:none;}
  .nav-links a{color:var(--slate);text-decoration:none;font-size:0.82rem;font-weight:500;letter-spacing:0.5px;text-transform:uppercase;transition:color 0.2s;}
  .nav-links a:hover{color:var(--accent);}

  /* ===================== SCROLL STACK ENGINE ===================== */
  .scroll-container{position:relative;}
  .scroll-panel{position:sticky;top:0;height:100vh;overflow:hidden;display:flex;flex-direction:column;justify-content:center;align-items:center;will-change:transform,opacity;}
  #hero-panel{background:var(--bg);opacity:1 !important;transform:none !important;filter:none !important;}
  .panel-inner{width:100%;max-width:1020px;margin:0 auto;padding:0 2rem;position:relative;z-index:2;}

  /* ===================== HERO ===================== */
  #hero-panel{background:var(--bg);}
  .hero-grid-bg{position:absolute;inset:0;background-image:linear-gradient(rgba(45,106,159,0.05) 1px,transparent 1px),linear-gradient(90deg,rgba(45,106,159,0.05) 1px,transparent 1px);background-size:60px 60px;pointer-events:none;}
  .hero-glow{position:absolute;top:40%;left:50%;transform:translate(-50%,-50%);width:700px;height:500px;background:radial-gradient(ellipse,rgba(45,106,159,0.09) 0%,transparent 70%);pointer-events:none;}
  #candleCanvas{position:absolute;inset:0;width:100%;height:100%;pointer-events:none;opacity:0.5;}
  .hero-eyebrow{display:inline-flex;align-items:center;gap:0.5rem;background:rgba(45,106,159,0.12);border:1px solid rgba(45,106,159,0.35);color:var(--accent);padding:0.3rem 1rem;border-radius:2px;font-size:0.75rem;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:2rem;}
  .hero-eyebrow::before{content:'';width:6px;height:6px;background:var(--blue2);border-radius:50%;animation:pulse 2s infinite;}
  @keyframes pulse{0%,100%{opacity:1;}50%{opacity:0.3;}}
  #hero-panel h1{font-size:clamp(2.8rem,7vw,5.2rem);font-weight:900;line-height:1.05;letter-spacing:-2px;margin-bottom:1.5rem;}
  #hero-panel h1 em{font-style:normal;color:var(--accent);position:relative;}
  #hero-panel h1 em::after{content:'';position:absolute;bottom:-4px;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--blue3),var(--blue2),var(--blue3));}
  .hero-sub{font-size:1.05rem;color:var(--slate);max-width:500px;margin:0 auto 3rem;line-height:1.7;}
  .hero-btns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-bottom:5rem;}
  .btn-primary{display:inline-block;background:var(--blue2);color:var(--white);font-weight:700;padding:0.8rem 2rem;border-radius:2px;text-decoration:none;font-size:0.88rem;letter-spacing:0.5px;text-transform:uppercase;transition:all 0.2s;}
  .btn-primary:hover{background:var(--blue);transform:translateY(-2px);}
  .btn-ghost{display:inline-block;border:1px solid rgba(45,106,159,0.4);color:var(--accent);font-weight:600;padding:0.8rem 2rem;border-radius:2px;text-decoration:none;font-size:0.88rem;letter-spacing:0.5px;text-transform:uppercase;transition:all 0.2s;}
  .btn-ghost:hover{background:rgba(45,106,159,0.1);}
  .hero-stats{display:flex;gap:0;border:1px solid var(--border);border-radius:2px;overflow:hidden;}
  .hstat{padding:1.5rem 2.5rem;text-align:center;background:var(--bg3);border-right:1px solid var(--border);}
  .hstat:last-child{border-right:none;}
  .hstat .val{font-size:1.9rem;font-weight:800;color:var(--accent);font-variant-numeric:tabular-nums;letter-spacing:-1px;}
  .hstat .lbl{font-size:0.72rem;color:var(--slate);letter-spacing:1px;text-transform:uppercase;margin-top:0.3rem;}

  /* ===================== PANEL COMMON ===================== */
  .sec-label{font-size:0.72rem;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--accent);margin-bottom:0.6rem;display:flex;align-items:center;gap:0.6rem;}
  .sec-label::before{content:'';display:inline-block;width:20px;height:1px;background:var(--blue2);}
  h2{font-size:clamp(1.8rem,3vw,2.5rem);font-weight:800;letter-spacing:-1px;margin-bottom:0.5rem;}
  .rule{width:40px;height:2px;background:var(--blue2);margin:1.5rem 0 2.5rem;}

  /* ===================== OM PANEL ===================== */
  #om-panel{background:var(--bg2);}
  .about-grid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start;}
  .about-body p{color:var(--slate);margin-bottom:1.1rem;font-size:1rem;}
  .about-body p b{color:var(--white);}
  .about-cards{display:flex;flex-direction:column;gap:1px;border:1px solid var(--border);border-radius:2px;overflow:hidden;}
  .acard{background:var(--bg3);padding:1.2rem 1.5rem;display:flex;gap:1rem;align-items:flex-start;transition:background 0.2s;}
  .acard:hover{background:var(--bg4);}
  .acard-icon{font-size:1.1rem;margin-top:0.15rem;min-width:24px;}
  .acard-title{font-weight:600;font-size:0.9rem;margin-bottom:0.2rem;color:var(--white);}
  .acard-desc{font-size:0.82rem;color:var(--slate);}

  /* ===================== PORTFOLIO PANEL ===================== */
  #portfolio-panel{background:var(--bg);}
  .port-table{width:100%;border-collapse:collapse;margin-bottom:1.5rem;}
  .port-table thead tr{border-bottom:1px solid var(--border);}
  .port-table th{font-size:0.7rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--slate);font-weight:500;padding:0.75rem 1rem;text-align:left;}
  .port-table th:last-child{text-align:right;}
  .port-table tbody tr{border-bottom:1px solid rgba(255,255,255,0.04);transition:background 0.15s;}
  .port-table tbody tr:hover{background:rgba(45,106,159,0.06);}
  .port-table td{padding:0.7rem 1rem;font-size:0.88rem;}
  .port-ticker{font-weight:700;font-size:0.78rem;letter-spacing:0.5px;color:var(--accent);}
  .port-name{color:var(--white);font-weight:500;}
  .port-ret{text-align:right;font-weight:700;}
  .up{color:var(--accent);}
  .dn{color:var(--red);}
  .port-section-head{font-size:0.7rem;letter-spacing:2px;text-transform:uppercase;color:var(--slate);padding:1rem 1rem 0.4rem;font-weight:500;}
  .port-disclaimer{font-size:0.76rem;color:var(--slate);font-style:italic;opacity:0.7;}
  .port-table tbody tr[data-stock]{cursor:pointer;}
  .port-table tbody tr[data-stock]:hover td{background:rgba(45,106,159,0.08);}
  .port-table tbody tr[data-stock] td:first-child::after{content:' ↗';font-size:0.65rem;color:rgba(74,158,255,0.45);}
  .port-scroll{overflow-y:auto;max-height:calc(100vh - 280px);}

  /* ===================== CONTENT PANEL ===================== */
  #content-panel{background:var(--bg2);}
  .content-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:2px;overflow:hidden;}
  .ccard{background:var(--bg3);padding:1.8rem;transition:background 0.2s;position:relative;overflow:hidden;}
  .ccard::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--blue3),transparent);opacity:0;transition:opacity 0.3s;}
  .ccard:hover{background:var(--bg4);}
  .ccard:hover::before{opacity:1;}
  .ccard-emoji{font-size:1.5rem;margin-bottom:1rem;display:block;}
  .ccard-tag{font-size:0.68rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--accent);font-weight:600;margin-bottom:0.5rem;}
  .ccard-title{font-size:0.95rem;font-weight:700;margin-bottom:0.5rem;color:var(--white);}
  .ccard-desc{font-size:0.82rem;color:var(--slate);line-height:1.6;}
  .tiktok-cta{text-align:center;margin-top:2.5rem;}
  .tiktok-cta p{color:var(--slate);font-size:0.88rem;margin-bottom:1rem;}

  /* ===================== REACH PANEL ===================== */
  #reach-panel{background:var(--bg);}
  .reach-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:2px;overflow:hidden;margin-bottom:3rem;}
  .rcard{background:var(--bg3);padding:2rem 1.5rem;text-align:center;}
  .rcard .rnum{font-size:2.2rem;font-weight:800;color:var(--accent);letter-spacing:-1px;}
  .rcard .rlbl{font-size:0.72rem;letter-spacing:1px;text-transform:uppercase;color:var(--slate);margin-top:0.4rem;}
  .partners-label{font-size:0.72rem;letter-spacing:2px;text-transform:uppercase;color:var(--slate);margin-bottom:1rem;}
  .partner-list{display:flex;flex-wrap:wrap;gap:0.75rem;}
  .pchip{border:1px solid var(--border);border-radius:2px;padding:0.5rem 1.1rem;font-size:0.82rem;font-weight:600;color:var(--light);background:var(--bg3);}

  /* ===================== COLLAB PANEL ===================== */
  #collab-panel{background:var(--bg2);}
  .collab-grid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start;}
  .collab-body p{color:var(--slate);margin-bottom:1rem;font-size:0.95rem;}
  .collab-list{list-style:none;margin-bottom:1.5rem;}
  .collab-list li{padding:0.75rem 0;border-bottom:1px solid rgba(255,255,255,0.05);font-size:0.9rem;color:var(--slate);display:flex;gap:0.75rem;}
  .collab-list li::before{content:'→';color:var(--accent);font-weight:700;flex-shrink:0;}
  .collab-list li b{color:var(--white);}
  .cform{background:var(--bg3);border:1px solid var(--border);border-radius:2px;padding:2.2rem;}
  .fgroup{margin-bottom:1.2rem;}
  .fgroup label{display:block;font-size:0.75rem;letter-spacing:1px;text-transform:uppercase;font-weight:600;color:var(--slate);margin-bottom:0.5rem;}
  .fgroup input,.fgroup textarea,.fgroup select{width:100%;background:var(--bg4);border:1px solid rgba(255,255,255,0.08);border-radius:2px;padding:0.75rem 1rem;color:var(--white);font-size:0.9rem;font-family:inherit;outline:none;transition:border-color 0.2s;}
  .fgroup input:focus,.fgroup textarea:focus,.fgroup select:focus{border-color:var(--blue2);}
  .fgroup textarea{height:100px;resize:vertical;}
  .fgroup select option{background:var(--bg4);}
  .btn-send{width:100%;background:var(--blue2);color:var(--white);font-weight:700;padding:0.9rem;border:none;border-radius:2px;font-size:0.85rem;letter-spacing:1px;text-transform:uppercase;cursor:pointer;font-family:inherit;transition:background 0.2s;}
  .btn-send:hover{background:var(--blue);}
  .form-note{font-size:0.75rem;color:var(--slate);margin-top:0.75rem;text-align:center;}

  /* ===================== FOOTER ===================== */
  footer{background:var(--bg);border-top:1px solid var(--border);padding:3rem 2rem 2rem;text-align:center;}
  .footer-logo{font-size:1rem;font-weight:800;color:var(--accent);letter-spacing:2px;text-transform:uppercase;margin-bottom:0.4rem;font-family:'Playfair Display',serif;}
  .footer-handle{color:var(--slate);font-size:0.82rem;margin-bottom:1.5rem;}
  .footer-links{display:flex;justify-content:center;gap:2rem;margin-bottom:2rem;flex-wrap:wrap;}
  .footer-links a{color:var(--slate);text-decoration:none;font-size:0.78rem;letter-spacing:0.5px;text-transform:uppercase;transition:color 0.2s;}
  .footer-links a:hover{color:var(--accent);}
  .footer-disc{font-size:0.74rem;color:rgba(136,153,170,0.6);max-width:560px;margin:0 auto 1rem;line-height:1.6;}
  .footer-copy{font-size:0.72rem;color:rgba(136,153,170,0.35);}

  /* ===================== MODAL ===================== */
  .modal-overlay{display:none;position:fixed;inset:0;background:rgba(4,8,18,0.85);z-index:300;backdrop-filter:blur(6px);align-items:center;justify-content:center;}
  .modal-overlay.open{display:flex;}
  .modal{background:var(--bg3);border:1px solid rgba(45,106,159,0.3);border-radius:4px;width:min(680px,92vw);max-height:85vh;overflow-y:auto;position:relative;animation:modalIn 0.3s cubic-bezier(0.22,1,0.36,1);}
  @keyframes modalIn{from{opacity:0;transform:translateY(24px) scale(0.97);}to{opacity:1;transform:translateY(0) scale(1);}}
  .modal-header{padding:1.8rem 2rem 1.2rem;border-bottom:1px solid rgba(45,106,159,0.15);display:flex;justify-content:space-between;align-items:flex-start;}
  .modal-ticker{font-size:0.72rem;letter-spacing:2px;text-transform:uppercase;color:var(--accent);font-weight:600;margin-bottom:0.3rem;}
  .modal-name{font-size:1.4rem;font-weight:800;font-family:'Playfair Display',serif;letter-spacing:-0.5px;}
  .modal-meta{font-size:0.8rem;color:var(--slate);margin-top:0.3rem;}
  .modal-close{background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);color:var(--slate);width:32px;height:32px;border-radius:2px;cursor:pointer;font-size:1.1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all 0.2s;}
  .modal-close:hover{background:rgba(255,255,255,0.12);color:var(--white);}
  .modal-kpi{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(45,106,159,0.1);border-bottom:1px solid rgba(45,106,159,0.15);}
  .kpi-cell{background:var(--bg3);padding:1rem 1.2rem;}
  .kpi-label{font-size:0.68rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--slate);margin-bottom:0.3rem;}
  .kpi-val{font-size:1rem;font-weight:700;color:var(--white);}
  .kpi-val.pos{color:var(--accent);}
  .kpi-val.neg{color:var(--red);}
  .modal-body{padding:1.5rem 2rem 2rem;}
  .modal-tese{background:rgba(45,106,159,0.07);border-left:2px solid var(--blue2);padding:0.8rem 1.1rem;border-radius:0 2px 2px 0;font-size:0.88rem;color:var(--light);font-style:italic;margin-bottom:1.5rem;line-height:1.6;}
  .modal-section{margin-bottom:1.4rem;}
  .modal-section-title{font-size:0.7rem;letter-spacing:2px;text-transform:uppercase;color:var(--accent);font-weight:600;margin-bottom:0.75rem;display:flex;align-items:center;gap:0.5rem;}
  .modal-section-title::after{content:'';flex:1;height:1px;background:rgba(45,106,159,0.2);}
  .modal-list{list-style:none;display:flex;flex-direction:column;gap:0.5rem;}
  .modal-list li{font-size:0.87rem;color:var(--slate);display:flex;gap:0.6rem;line-height:1.5;}
  .modal-list.triggers li::before{content:'↑';color:var(--accent);font-weight:700;flex-shrink:0;}
  .modal-list.challenges li::before{content:'↓';color:var(--red);font-weight:700;flex-shrink:0;}

  /* ===================== EDIT BAR ===================== */
  .edit-bar{position:fixed;bottom:0;left:0;right:0;z-index:200;background:rgba(8,12,20,0.97);border-top:1px solid var(--border);padding:0.7rem 2rem;display:flex;align-items:center;gap:1rem;}
  .edit-bar span{color:var(--slate);font-size:0.82rem;}
  .edit-toggle{background:var(--blue2);color:var(--white);font-weight:700;border:none;padding:0.45rem 1.2rem;border-radius:2px;cursor:pointer;font-size:0.8rem;letter-spacing:0.5px;text-transform:uppercase;font-family:inherit;}
  .edit-toggle.active{background:var(--red);}
  .save-btn{background:transparent;color:var(--accent);border:1px solid rgba(45,106,159,0.4);font-weight:600;padding:0.45rem 1.1rem;border-radius:2px;cursor:pointer;font-size:0.8rem;font-family:inherit;}
  .edit-hint{margin-left:auto;color:var(--slate);font-size:0.78rem;}
  [contenteditable="true"]{outline:1px dashed rgba(45,106,159,0.5);border-radius:1px;cursor:text;}
  [contenteditable="true"]:focus{outline:1px solid var(--blue2);background:rgba(45,106,159,0.05);}

  /* ===================== PROGRESS BAR ===================== */
  .scroll-progress{position:fixed;top:0;left:0;height:2px;background:linear-gradient(90deg,var(--blue2),var(--accent));z-index:999;transition:width 0.1s linear;width:0%;}

  /* ===================== SECTION INDICATOR ===================== */
  .section-dots{position:fixed;right:2rem;top:50%;transform:translateY(-50%);z-index:150;display:flex;flex-direction:column;gap:0.75rem;}
  .sdot{width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,0.2);cursor:pointer;transition:all 0.3s;border:1px solid rgba(45,106,159,0.3);}
  .sdot.active{background:var(--accent);transform:scale(1.5);}
  .sdot:hover{background:var(--blue2);}

  @media(max-width:700px){
    nav{padding:0.9rem 1.2rem;} .nav-links{display:none;}
    .about-grid,.collab-grid{grid-template-columns:1fr;}
    .hero-stats{flex-direction:column;border:none;} .hstat{border-right:none;border-bottom:1px solid var(--border);}
    .content-grid{grid-template-columns:1fr;} .reach-grid{grid-template-columns:1fr 1fr;}
    .section-dots{display:none;}
    .scroll-panel{height:auto;position:relative;padding:6rem 0;}
  }
</style>
</head>
