function openStock(key){
  const s=STOCKS[key];if(!s)return;
  document.getElementById('m-ticker').textContent=s.ticker;
  document.getElementById('m-name').textContent=s.name;
  document.getElementById('m-meta').textContent=s.sektor+' · Vekting '+s.vekting+' · GAV '+s.gav;
  document.getElementById('m-tese').textContent='Min tese: '+s.tese;
  const isPos=!s.avkastning.startsWith('−');
  document.getElementById('m-kpi').innerHTML=s.kpi.map(k=>`<div class="kpi-cell"><div class="kpi-label">${k.l}</div><div class="kpi-val">${k.v}</div></div>`).join('')+`<div class="kpi-cell"><div class="kpi-label">Avkastning</div><div class="kpi-val ${isPos?'pos':'neg'}">${s.avkastning}</div></div>`;
  document.getElementById('m-triggers').innerHTML=s.triggers.map(t=>`<li>${t}</li>`).join('');
  document.getElementById('m-challenges').innerHTML=s.challenges.map(c=>`<li>${c}</li>`).join('');
  document.getElementById('stockModal').classList.add('open');
  document.body.style.overflow='hidden';
}
function closeModal(e){if(e.target===document.getElementById('stockModal'))closeModalDirect();}
function closeModalDirect(){document.getElementById('stockModal').classList.remove('open');document.body.style.overflow='';}
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeModalDirect();});
document.querySelectorAll('tr[data-stock]').forEach(row=>{
  row.addEventListener('click',()=>openStock(row.dataset.stock));
});

