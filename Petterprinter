<script>
/* ============================================================
   CINEMATIC SCROLL ENGINE
   Each section panel uses position:sticky so it stays visible
   while the user scrolls through its "height" window.
   We track scroll progress per panel and drive:
   - outgoing panel: scale down + fade out upward
   - incoming panel: scale up + fade in from below
   ============================================================ */
const panels = Array.from(document.querySelectorAll('.section-block'));
const panelEls = panels.map(p => p.querySelector('.scroll-panel'));
const dots = Array.from(document.querySelectorAll('.sdot'));
const progressBar = document.getElementById('scrollProgress');
const nav = document.getElementById('mainNav');
let currentPanel = 0;
let ticking = false;

function lerp(a,b,t){return a+(b-a)*t;}
function clamp(v,lo,hi){return Math.max(lo,Math.min(hi,v));}
function easeOut(t){return 1-Math.pow(1-t,3);}
function easeIn(t){return t*t*t;}

function updateScroll(){
  const scrollY = window.scrollY;
  const docH = document.documentElement.scrollHeight - window.innerHeight;
  progressBar.style.width = (scrollY/docH*100)+'%';

  // Hide ticker when scrolled
  nav.classList.toggle('scrolled', scrollY > 40);

  panels.forEach((block, i) => {
    const panel = panelEls[i];
    const blockTop = block.offsetTop;
    const blockH = block.offsetHeight;
    // progress within this block: 0 = entering, 1 = leaving
    const raw = (scrollY - blockTop) / blockH;
    const progress = clamp(raw, 0, 1);

    // Hero panel: only animate out, never hide on entry
    if(i === 0){
      if(raw <= 0){
        // at top — fully visible, no transform
        panel.style.transform = '';
        panel.style.opacity = '1';
        panel.style.filter = '';
        return;
      }
      // scroll out: scale + fade upward in second half of its 200vh block
      const outP = clamp((raw - 0.5) * 2, 0, 1);
      const ty = -easeIn(outP) * 80;
      const sc = lerp(1, 0.92, easeIn(outP));
      const op = lerp(1, 0, easeIn(outP));
      const bl = easeIn(outP) * 6;
      panel.style.transform = `translateY(${ty}px) scale(${sc})`;
      panel.style.opacity = op;
      panel.style.filter = bl > 0.1 ? `blur(${bl}px)` : '';
      return;
    }

    // Outgoing: as we scroll past bottom half, push panel up + fade
    let ty = 0, scale = 1, opacity = 1, blur = 0;

    if(raw < 0){
      // first panel: always fully visible at top
      if(i === 0){
        ty = 0; scale = 1; opacity = 1;
      } else {
        ty = clamp(-raw, 0, 1) * 60;
        opacity = clamp(1+raw*3, 0, 1);
        scale = lerp(0.94, 1, clamp(1+raw*3, 0, 1));
      }
    } else if(raw > 0 && raw < 1){
      // panel is active, push outgoing up as next panel arrives
      const outP = clamp((raw-0.5)*2, 0, 1);
      ty = -easeIn(outP) * 80;
      scale = lerp(1, 0.92, easeIn(outP));
      opacity = lerp(1, 0, easeIn(outP));
      blur = easeIn(outP) * 6;
    } else {
      // fully scrolled past
      opacity = 0;
      ty = -80;
      scale = 0.92;
    }

    panel.style.transform = `translateY(${ty}px) scale(${scale})`;
    panel.style.opacity = opacity;
    panel.style.filter = blur > 0.1 ? `blur(${blur}px)` : '';

    // Active dot tracking
    if(raw >= 0 && raw < 1) currentPanel = i;
  });

  dots.forEach((d,i)=>{d.classList.toggle('active', i===currentPanel);});
  ticking = false;
}

window.addEventListener('scroll', ()=>{
  if(!ticking){requestAnimationFrame(updateScroll); ticking=true;}
}, {passive:true});
updateScroll();

// Dot click navigation
dots.forEach((d,i)=>{
  d.addEventListener('click',()=>{
    const target = document.getElementById(d.dataset.target);
    if(target) window.scrollTo({top:target.offsetTop, behavior:'smooth'});
  });
});

/* ============================================================
   CANDLESTICK BACKGROUND
   ============================================================ */
(function(){
  const canvas=document.getElementById('candleCanvas');
  if(!canvas)return;
  const ctx=canvas.getContext('2d');
  let W,H,candles=[],frame=0;
  const UP='rgba(45,106,159,0.65)',DN='rgba(180,70,70,0.5)',UPw='rgba(45,106,159,0.35)',DNw='rgba(180,70,70,0.3)';
  function resize(){W=canvas.width=canvas.offsetWidth;H=canvas.height=canvas.offsetHeight;}
  function gen(){
    candles=[];
    const cw=18,gap=10,count=Math.floor(W/(cw+gap))+4;
    let price=200;
    for(let i=0;i<count;i++){
      const chg=(Math.random()-0.46)*12;
      const o=price,c=price+chg;
      candles.push({o,c,hi:Math.max(o,c)+(Math.random()*6),lo:Math.min(o,c)-(Math.random()*6),x:-cw*2+i*(cw+gap),w:cw});
      price=c;
    }
  }
  function draw(){
    ctx.clearRect(0,0,W,H);
    const minP=Math.min(...candles.map(c=>c.lo))-20;
    const maxP=Math.max(...candles.map(c=>c.hi))+20;
    const yBot=H*0.85,yTop=H*0.12,scale=(yBot-yTop)/(maxP-minP);
    const py=p=>yBot-(p-minP)*scale;
    candles.forEach(cd=>{
      const bull=cd.c>=cd.o,x=cd.x+frame*0.4;
      if(x<-cd.w-2||x>W+2)return;
      ctx.strokeStyle=bull?UPw:DNw;ctx.lineWidth=1;
      ctx.beginPath();ctx.moveTo(x+cd.w/2,py(cd.hi));ctx.lineTo(x+cd.w/2,py(cd.lo));ctx.stroke();
      ctx.fillStyle=bull?UP:DN;
      ctx.fillRect(x,py(Math.max(cd.o,cd.c)),cd.w,Math.max(1,Math.abs(py(cd.o)-py(cd.c))));
    });
    ctx.beginPath();ctx.strokeStyle='rgba(45,106,159,0.15)';ctx.lineWidth=1.5;
    let first=true;
    candles.filter(cd=>cd.x+frame*0.4>-10&&cd.x+frame*0.4<W+10).forEach((cd,i,arr)=>{
      if(i<4)return;
      const avg=arr.slice(i-4,i+1).reduce((a,b)=>a+(b.o+b.c)/2,0)/5;
      const x=cd.x+frame*0.4+cd.w/2;
      if(first){ctx.moveTo(x,py(avg));first=false;}else ctx.lineTo(x,py(avg));
    });
    ctx.stroke();
    frame++;
    if(frame*0.4>candles[0].w+10)frame=0;
    requestAnimationFrame(draw);
  }
  window.addEventListener('resize',()=>{resize();gen();});
  resize();gen();draw();
})();

/* ============================================================
   MAGNETIC CARD TILT
   ============================================================ */
document.querySelectorAll('.hstat,.rcard,.ccard,.acard').forEach(card=>{
  card.addEventListener('mousemove',e=>{
    const r=card.getBoundingClientRect();
    const x=(e.clientX-r.left-r.width/2)/(r.width/2);
    const y=(e.clientY-r.top-r.height/2)/(r.height/2);
    card.style.transform=`perspective(600px) rotateY(${x*6}deg) rotateX(${-y*6}deg) translateZ(8px)`;
    card.style.boxShadow=`${-x*8}px ${-y*8}px 24px rgba(45,106,159,0.2)`;
  });
  card.addEventListener('mouseleave',()=>{
    card.style.transform='';card.style.boxShadow='';
    card.style.transition='transform 0.5s ease,box-shadow 0.5s ease';
  });
  card.addEventListener('mouseenter',()=>{card.style.transition='transform 0.1s ease,box-shadow 0.1s ease';});
});

/* ============================================================
   COUNTER ANIMATION
   ============================================================ */
function animateCounters(){
  document.querySelectorAll('.hstat .val').forEach(el=>{
    const txt=el.textContent.trim();
    const num=parseFloat(txt.replace(',','.').replace('%','').replace('+',''));
    if(isNaN(num)||txt==='BI'||txt.includes('–'))return;
    const isPlus=txt.startsWith('+'),isPct=txt.includes('%');
    const decimals=txt.includes(',')?(txt.split(',')[1]||'').replace('%','').replace('+','').length:0;
    let start=null;
    function step(ts){
      if(!start)start=ts;
      const p=Math.min((ts-start)/1400,1);
      const ease=1-Math.pow(1-p,3);
      el.textContent=(isPlus?'+':('' ))+(num*ease).toFixed(decimals).replace('.',',')+(isPct?'%':'');
      if(p<1)requestAnimationFrame(step); else el.textContent=txt;
    }
    requestAnimationFrame(step);
  });
}
const obs=new IntersectionObserver(e=>{e.forEach(en=>{if(en.isIntersecting){animateCounters();obs.disconnect();}});},{threshold:0.3});
const se=document.querySelector('.hero-stats');
if(se)obs.observe(se);

